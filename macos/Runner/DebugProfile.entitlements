<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Chat requests to the OpenRouter API. -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- In-app voice-note recording (the record package). -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- Attaching files and saving replies via open/save panels. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- flutter_secure_storage keeps the API key in the Keychain; a sandboxed
	     app needs an explicit keychain access group. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)net.ryandam.wombat</string>
	</array>
</dict>
</plist>
